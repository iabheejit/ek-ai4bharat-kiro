{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListCertificateBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::ekatra-certificates",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "certificates/*"
          ]
        }
      }
    },
    {
      "Sid": "ManageCertificateObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::ekatra-certificates/certificates/*"
    }
  ]
}